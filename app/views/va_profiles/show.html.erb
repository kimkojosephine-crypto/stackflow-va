<div style="max-width:640px; margin:3rem auto; padding:0 1rem;">

  <h1 style="color:#1B3A6B; margin-bottom:0.25rem;">Your StackFlow VA Toolkit</h1>
  <p style="color:#555; margin-bottom:2rem;">
    Personalised tool stack for a <strong><%= @va_profile.niche %></strong>
    with a $<%= @va_profile.budget %>/month budget.
  </p>

  <% tools = recommend_tools(@va_profile.niche, @va_profile.budget) %>

  <% if tools.any? %>
    <% tools.each do |tool| %>
      <div style="border:1px solid #e0e0e0; border-radius:8px; padding:1rem 1.25rem;
                  margin-bottom:1rem; display:flex; justify-content:space-between;
                  align-items:flex-start;">
        <div>
          <strong style="font-size:1.1rem; color:#1B3A6B;"><%= tool[:name] %></strong>
          <p style="margin:0.25rem 0 0; color:#555; font-size:0.95rem;">
            <%= tool[:desc] %>
          </p>
        </div>
        <span style="font-size:0.8rem; padding:0.25rem 0.6rem; border-radius:20px;
                     white-space:nowrap; margin-left:1rem;
                     <%= tool[:free] ? 'background:#e1f5ee; color:#0f6e56;' : 'background:#faeeda; color:#854f0b;' %>">
          <%= tool[:free] ? "Free" : "Paid" %>
        </span>
      </div>
    <% end %>
  <% else %>
    <div style="border:1px solid #f0c0b0; border-radius:8px; padding:1rem;
                background:#faece7; color:#993c1d;">
      <strong>No free tools found for this niche.</strong>
      Try increasing your budget above $50 to unlock more recommendations.
    </div>
  <% end %>

  <div style="margin-top:2rem; padding:1rem; background:#f5f7fa;
              border-radius:8px; font-size:0.9rem; color:#555;">
    <strong>Profile saved</strong> — Niche: <%= @va_profile.niche %> ·
    Budget: $<%= @va_profile.budget %>/mo ·
    Tools shown: <%= tools.count %>
  </div>

  <div style="margin-top:1.5rem; display:flex; gap:1rem;">
    <%= link_to "← Generate a new stack", new_va_profile_path,
      style: "background:#1B3A6B; color:white; padding:0.6rem 1.25rem;
              border-radius:6px; text-decoration:none; font-size:0.95rem;" %>
    <%= link_to "View all profiles →", va_profiles_path,
      style: "background:white; color:#1B3A6B; padding:0.6rem 1.25rem;
              border-radius:6px; text-decoration:none; font-size:0.95rem;
              border:1px solid #1B3A6B;" %>
  </div>

</div>
